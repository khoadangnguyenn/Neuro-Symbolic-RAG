<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d4" for="edge" attr.name="relation" attr.type="string" />
  <key id="d3" for="node" attr.name="variables" attr.type="string" />
  <key id="d2" for="node" attr.name="verified_by_executor" attr.type="boolean" />
  <key id="d1" for="node" attr.name="is_dynamic" attr.type="boolean" />
  <key id="d0" for="node" attr.name="text" attr.type="string" />
  <graph edgedefault="directed">
    <node id="capacitor_energy_voltage">
      <data key="d0">capacitor energy stored capacitance voltage E = 0.5*C*U^2 Use SI units: C in farads, U in volts, E in joules.</data>
      <data key="d1">False</data>
    </node>
    <node id="capacitor_charge">
      <data key="d0">capacitor charge stores fully charged Q = C*U A fully charged capacitor stores charge equal to capacitance times voltage.</data>
      <data key="d1">False</data>
    </node>
    <node id="capacitance">
      <data key="d0">capacitance charge voltage capacitor C = Q/U Capacitance is charge divided by voltage.</data>
      <data key="d1">False</data>
    </node>
    <node id="parallel_plate_capacitance">
      <data key="d0">parallel plate area distance dielectric capacitance C = epsilon0*epsilon_r*A/d For parallel plates, convert area and distance to SI before computing.</data>
      <data key="d1">False</data>
    </node>
    <node id="ohm_law_current">
      <data key="d0">current voltage resistance ohm I = U/R Ohm's law relates voltage, current, and resistance.</data>
      <data key="d1">False</data>
    </node>
    <node id="ohm_law_voltage">
      <data key="d0">voltage current resistance potential difference U = I*R Voltage equals current times resistance.</data>
      <data key="d1">False</data>
    </node>
    <node id="electric_power">
      <data key="d0">power current voltage resistance watt P = U*I = I^2*R = U^2/R Pick the electric-power form matching the given quantities.</data>
      <data key="d1">False</data>
    </node>
    <node id="resistors_series">
      <data key="d0">series equivalent total resistance resistor R_eq = sum(R_i) Ideal series resistances add directly.</data>
      <data key="d1">False</data>
    </node>
    <node id="resistors_parallel">
      <data key="d0">parallel equivalent total resistance resistor 1/R_eq = sum(1/R_i) Ideal parallel resistances add by reciprocals.</data>
      <data key="d1">False</data>
    </node>
    <node id="charge_transport">
      <data key="d0">charge current time passes transport Q = I*t Charge transported by a steady current equals current times time.</data>
      <data key="d1">False</data>
    </node>
    <node id="coulomb_force">
      <data key="d0">coulomb force charge distance separation F = k*abs(q1*q2)/r^2 Use k = 9e9 N*m^2/C^2 in air/vacuum unless stated otherwise.</data>
      <data key="d1">False</data>
    </node>
    <node id="equal_charge_coulomb">
      <data key="d0">equal charges find force separated q = sqrt(F*r^2/k) For two equal charges, invert Coulomb's law.</data>
      <data key="d1">False</data>
    </node>
    <node id="electric_field_point">
      <data key="d0">electric field strength intensity point charge E = k*abs(q)/r^2 Point-charge electric field uses charge magnitude and distance.</data>
      <data key="d1">False</data>
    </node>
    <node id="electric_force_field">
      <data key="d0">electric field force charge intensity F = abs(q)*E Force on a charge in an electric field is charge magnitude times field strength.</data>
      <data key="d1">False</data>
    </node>
    <node id="uniform_field_voltage">
      <data key="d0">uniform field voltage distance plates U = E*d Uniform field voltage equals field strength times plate separation.</data>
      <data key="d1">False</data>
    </node>
    <node id="resultant_two_forces">
      <data key="d0">resultant force angle same opposite perpendicular R = sqrt(F1^2 + F2^2 + 2*F1*F2*cos(theta)) Use vector addition; same direction adds, opposite subtracts, perpendicular uses Pythagoras.</data>
      <data key="d1">False</data>
    </node>
    <node id="capacitor_energy">
      <data key="d0">capacitor energy voltage capacitance E = 0.5 × C × U^2 To calculate the energy stored in a capacitor given its capacitance and voltage.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["E", "C", "U"]</data>
    </node>
    <node id="capacitance_formula">
      <data key="d0">capacitance charge voltage C = Q / U This formula is used to calculate the capacitance of a capacitor when the charge and voltage are known.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["C", "Q", "U"]</data>
    </node>
    <node id="coulombs_law">
      <data key="d0">electrostatic force charges distance F = k × |q1×q2| / r^2 To calculate the electrostatic force between two point charges.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "q1", "q2", "r"]</data>
    </node>
    <node id="resultant_force">
      <data key="d0">forces same direction resultant add F_resultant = F1 + F2 When forces are acting in the same direction, add their magnitudes to find the resultant force.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["F_resultant", "F1", "F2"]</data>
    </node>
    <node id="pythagorean_theorem">
      <data key="d0">forces perpendicular resultant magnitude F_resultant = sqrt(F1^2 + F2^2) When forces are perpendicular to each other</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["F_resultant", "F1", "F2"]</data>
    </node>
    <node id="electric_force">
      <data key="d0">electric force charges distance F = k * |q1 * q2| / r^2 To calculate the electric force between two point charges</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "q1", "q2", "r"]</data>
    </node>
    <node id="electric_field_point_charge">
      <data key="d0">electric field point charge distance E = k * |q| / r² To calculate the electric field due to a point charge</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "|q|", "r"]</data>
    </node>
    <node id="electric_field_strength">
      <data key="d0">electric field point charge distance E = k * |q| / r^2 To calculate the electric field strength due to a point charge</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "|q|", "r"]</data>
    </node>
    <node id="electric_field_due_to_point_charge">
      <data key="d0">electric field point charge distance Coulomb's constant E = k * |q| / r^2 To calculate the electric field due to a point charge in a vacuum.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "|q|", "r"]</data>
    </node>
    <node id="electric_field_coulombs_law">
      <data key="d0">electric field point charge Coulomb's law E = k * |q| / r² To calculate the electric field due to a point charge in a vacuum.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "|q|", "r"]</data>
    </node>
    <node id="electric_field_ratio">
      <data key="d0">electric field point charges net electric field zero k * |q1| / x_AC^2 = k * |q2| / x_BC^2 When finding the point where the net electric field due to multiple point charges is zero.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "|q1|", "x_AC", "|q2|", "x_BC"]</data>
    </node>
    <node id="electric_field">
      <data key="d0">electric field point charge distance vacuum E = k * |q| / r^2 To calculate the electric field due to a point charge in a vacuum.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "|q|", "r"]</data>
    </node>
    <node id="electric_field_cancellation">
      <data key="d0">electric field cancellation midpoint equal charges E = 0 V/m When two equal and opposite electric fields cancel each other at a point</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["E"]</data>
    </node>
    <node id="electric_field_superposition">
      <data key="d0">electric field superposition equilateral triangle center identical charges E_total = 0 When multiple electric fields are present and need to be summed up.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["E_total"]</data>
    </node>
    <node id="electric_field_right_isosceles_triangle">
      <data key="d0">electric field right isosceles triangle charges foot of the altitude E_H = sqrt((k * q / (a/2)^2)^2 + (2 * k * q / a^2)^2) To find the electric field intensity at the foot of the altitude in a right isosceles triangle with charges at the vertices.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["k", "q", "a"]</data>
    </node>
    <node id="electric_field_vector_sum">
      <data key="d0">electric field vector sum resultant E_H = sqrt((E_B - E_C)^2 + E_A^2) To find the resultant electric field vector at a point due to multiple point charges.</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["E_H", "E_A", "E_B", "E_C"]</data>
    </node>
