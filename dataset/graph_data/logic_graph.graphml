<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d5" for="edge" attr.name="relation" attr.type="string" />
  <key id="d4" for="node" attr.name="conclusion_predicates" attr.type="string" />
  <key id="d3" for="node" attr.name="premise_predicates" attr.type="string" />
  <key id="d2" for="node" attr.name="verified_by_executor" attr.type="boolean" />
  <key id="d1" for="node" attr.name="is_dynamic" attr.type="boolean" />
  <key id="d0" for="node" attr.name="text" attr.type="string" />
  <graph edgedefault="directed">
    <node id="logic_rule_1822907814065572306">
      <data key="d0">Translate each natural-language clause into a unary predicate or a Horn rule when possible.</data>
      <data key="d1">False</data>
    </node>
    <node id="logic_rule_6003336773337392133">
      <data key="d0">Use ground facts for named students/entities, for example completed_core(Sophia).</data>
      <data key="d1">False</data>
    </node>
    <node id="logic_rule_-3155018407589198030">
      <data key="d0">Use ForAll(x, A(x) -&gt; B(x)) for universal if-then regulations.</data>
      <data key="d1">False</data>
    </node>
    <node id="logic_rule_5697752616286079668">
      <data key="d0">Use And(...) or conjunction when a rule has multiple required conditions.</data>
      <data key="d1">False</data>
    </node>
    <node id="logic_rule_-6028639661725539572">
      <data key="d0">Answer Yes only when the conclusion follows from the premises; answer No when a negated conclusion follows; otherwise answer Uncertain.</data>
      <data key="d1">False</data>
    </node>
    <node id="logic_rule_208619012827854499">
      <data key="d0">For multiple-choice questions, compare each option against the premise graph and prefer the strongest directly supported option.</data>
      <data key="d1">False</data>
    </node>
    <node id="logic_rule_2264211343279275958">
      <data key="d0">Cite premise numbers in the explanation whenever a rule or fact is used.</data>
      <data key="d1">False</data>
    </node>
    <node id="logic_rule_f3f9055ef436dc998758ecb2019102a5">
      <data key="d0">Pattern: If a Python code is well-tested, then the project is optimized. -&gt; ∀x (WT(x) → O(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["WT"]</data>
      <data key="d4">["O"]</data>
    </node>
    <node id="logic_rule_938f38b9cc5ec900c1dfb4a345212a14">
      <data key="d0">Pattern: If a Python code does not follow PEP 8 standards, then it is not well-tested. -&gt; ∀x (¬PEP8(x) → ¬WT(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["PEP8"]</data>
      <data key="d4">["WT"]</data>
    </node>
    <node id="logic_rule_b12c7a7f759be580776f824e4baa44f2">
      <data key="d0">Pattern: If a Python code follows PEP 8 standards, then it is easy to maintain. -&gt; ∀x (PEP8(x) → EM(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["PEP8"]</data>
      <data key="d4">["EM"]</data>
    </node>
    <node id="logic_rule_f4a74ceefddfbb20b4ab35a11bf616da">
      <data key="d0">Pattern: If a Python code is well-tested, then it follows PEP 8 standards. -&gt; ∀x (WT(x) → PEP8(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["WT"]</data>
      <data key="d4">["PEP8"]</data>
    </node>
    <node id="logic_rule_e6c076d2ae04da10f0f09ca242a39217">
      <data key="d0">Pattern: If a Python project is well-structured, then it is optimized. -&gt; ∀x (WS(x) → O(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["WS"]</data>
      <data key="d4">["O"]</data>
    </node>
    <node id="logic_rule_c32be7943fb311c7b21bd04eb3fdee8f">
      <data key="d0">Pattern: If a Python project is easy to maintain, then it is well-tested. -&gt; ∀x (EM(x) → WT(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["easy to maintain"]</data>
      <data key="d4">["well-tested"]</data>
    </node>
    <node id="logic_rule_c2b9e6e8c74ea65588721f6d62a88039">
      <data key="d0">Pattern: If a Python project is optimized, then it has clean and readable code. -&gt; ∀x (O(x) → CR(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["O"]</data>
      <data key="d4">["CR"]</data>
    </node>
    <node id="logic_rule_97118b784e845966481eef504da82932">
      <data key="d0">Pattern: If a Python project is not well-structured, then it does not follow PEP 8 standards. -&gt; ∀x (¬WS(x) → ¬PEP8(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["WS"]</data>
      <data key="d4">["PEP8"]</data>
    </node>
    <node id="logic_rule_85ab3b09e856e220736a17adc71e27a8">
      <data key="d0">Pattern: Students who have completed the core curriculum and passed the science assessment are qualified for advanced courses. -&gt; ForAll(x, (completed_core_curriculum(x) ∧ passed_science_assessment(x)) → qualified_for_advanced_courses(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["completed_core_curriculum", "passed_science_assessment"]</data>
      <data key="d4">["qualified_for_advanced_courses"]</data>
    </node>
    <node id="logic_rule_179f83e0810cbca924deaaa0cce91801">
      <data key="d0">Pattern: Students who are qualified for advanced courses and have completed research methodology are eligible for the international program. -&gt; ForAll(x, (qualified_for_advanced_courses(x) ∧ completed_research_methodology(x)) → eligible_for_international_program(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["qualified_for_advanced_courses", "completed_research_methodology"]</data>
      <data key="d4">["eligible_for_international_program"]</data>
    </node>
    <node id="logic_rule_4a9f341f70dcde7b5c40a26c92c1206b">
      <data key="d0">Pattern: Students who have passed the language proficiency exam are eligible for the international program. -&gt; ForAll(x, passed_language_proficiency(x) → eligible_for_international_program(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["passed_language_proficiency"]</data>
      <data key="d4">["eligible_for_international_program"]</data>
    </node>
    <node id="logic_rule_5a8b955ca83e5162a5725fc09d0cb34e">
      <data key="d0">Pattern: Students who are eligible for the international program and have completed a capstone project are awarded an honors diploma. -&gt; ForAll(x, (eligible_for_international_program(x) ∧ completed_capstone_project(x)) → awarded_honors_diploma(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["eligible_for_international_program", "completed_capstone_project"]</data>
      <data key="d4">["awarded_honors_diploma"]</data>
    </node>
    <node id="logic_rule_a1b7ece2660c7f42895723a616dda48a">
      <data key="d0">Pattern: Students who have been awarded an honors diploma and have completed community service qualify for the university scholarship. -&gt; ForAll(x, (awarded_honors_diploma(x) ∧ completed_community_service(x)) → qualifies_for_scholarship(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
    </node>
    <node id="logic_rule_1351801e489d3c7a1d2f2a4bf18c5d46">
      <data key="d0">Pattern: Students who have been awarded an honors diploma and have received a faculty recommendation qualify for the university scholarship. -&gt; ForAll(x, (awarded_honors_diploma(x) ∧ received_faculty_recommendation(x)) → qualifies_for_scholarship(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["awarded_honors_diploma", "received_faculty_recommendation"]</data>
      <data key="d4">["qualifies_for_scholarship"]</data>
    </node>
    <node id="logic_rule_53b2510135d55e4df3abfcd44b3599fb">
      <data key="d0">Pattern: If a student completes all required courses, they are eligible for graduation. -&gt; ForAll(x, completed_required_courses(x) → eligible_for_graduation(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["completed_required_courses"]</data>
      <data key="d4">["eligible_for_graduation"]</data>
    </node>
    <node id="logic_rule_4a8dfd24aaed1196df99ccb09d993179">
      <data key="d0">Pattern: If a student is eligible for graduation and maintains a GPA above 3.5, they graduate with honors. -&gt; ForAll(x, (eligible_for_graduation(x) ∧ gpa_above_3_5(x)) → graduates_with_honors(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["eligible_for_graduation", "gpa_above_3_5"]</data>
      <data key="d4">["graduates_with_honors"]</data>
    </node>
    <node id="logic_rule_85790bd1c17a2c1b49ee69a6844988f6">
      <data key="d0">Pattern: If a student graduates with honors and completes a thesis, they receive academic distinction. -&gt; ForAll(x, (graduates_with_honors(x) ∧ completed_thesis(x)) → academic_distinction(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["graduates_with_honors", "completed_thesis"]</data>
      <data key="d4">["academic_distinction"]</data>
    </node>
    <node id="logic_rule_8c2b54fecebefbb4f78d8ac4db4d4d24">
      <data key="d0">Pattern: If a student receives academic distinction, they qualify for the graduate fellowship program. -&gt; ForAll(x, academic_distinction(x) → qualifies_for_fellowship(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["academic_distinction"]</data>
      <data key="d4">["qualifies_for_fellowship"]</data>
    </node>
    <node id="logic_rule_71e003234ef177a4429d53bc6311b65a">
      <data key="d0">Pattern: If a faculty member has completed training, they can teach undergraduate courses. -&gt; ForAll(x, completed_pedagogical_training(x) → can_teach_undergraduate(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["completed_pedagogical_training"]</data>
      <data key="d4">["can_teach_undergraduate"]</data>
    </node>
    <node id="logic_rule_54a0d6e2f1276de9b3d5c8c13bff9e8a">
      <data key="d0">Pattern: If a faculty member can teach undergraduate courses and holds a PhD, they can supervise graduate students. -&gt; ForAll(x, (can_teach_undergraduate(x) ∧ holds_phd(x)) → can_supervise_graduate(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
    </node>
    <node id="logic_rule_bbc010c4696bf84563925d5c125b203f">
      <data key="d0">Pattern: If a faculty member can supervise graduate students and has at least 3 publications, they can serve on curriculum committees. -&gt; ForAll(x, (can_supervise_graduate(x) ∧ has_at_least_three_publications(x)) → can_serve_curriculum_committees(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["can_supervise_graduate", "has_at_least_three_publications"]</data>
      <data key="d4">["can_serve_curriculum_committees"]</data>
    </node>
    <node id="logic_rule_f0a5e09dab10fcdb6f09d86591a1ece0">
      <data key="d0">Pattern: If a faculty member can serve on curriculum committees and has a positive teaching evaluation, they can propose new courses. -&gt; ForAll(x, (can_serve_curriculum_committees(x) ∧ has_positive_evaluation(x)) → can_propose_courses(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["can_serve_curriculum_committees", "has_positive_evaluation"]</data>
      <data key="d4">["can_propose_courses"]</data>
    </node>
    <node id="logic_rule_e5330c0a63a4271ac009af8a1e3e87fd">
      <data key="d0">Pattern: If a faculty member has taught for at least 5 years, they are eligible for extended library access. -&gt; ForAll(x, taught_min_five_years(x) → eligible_extended_library(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["taught_min_five_years"]</data>
      <data key="d4">["eligible_extended_library"]</data>
    </node>
    <node id="logic_rule_86da68d3b4ebbddafe6e1e075632aad9">
      <data key="d0">Pattern: If someone has extended library access and has published at least one academic paper, they can access restricted archives. -&gt; ForAll(x, (eligible_extended_library(x) ∧ has_publications(x)) → can_access_restricted_archives(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
    </node>
    <node id="logic_rule_80d0f9caaf7bd7ce8ab18181fef2bd17">
      <data key="d0">Pattern: If someone can access restricted archives and has completed research ethics training, they can submit research proposals. -&gt; ForAll(x, (can_access_restricted_archives(x) ∧ completed_ethics_training(x)) → can_submit_research_proposals(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["can_access_restricted_archives", "completed_ethics_training"]</data>
      <data key="d4">["can_submit_research_proposals"]</data>
    </node>
    <node id="logic_rule_ea6200e593a946477dd2a9e443717f8e">
      <data key="d0">Pattern: If someone can submit research proposals and has a departmental endorsement, they can apply for collaborative research projects. -&gt; ForAll(x, (can_submit_research_proposals(x) ∧ has_departmental_endorsement(x)) → can_apply_collaborative_projects(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["can_submit_research_proposals", "has_departmental_endorsement"]</data>
      <data key="d4">["can_apply_collaborative_projects"]</data>
    </node>
    <node id="logic_rule_1bd0e5ffb82a05b5420a9ecc70e94eb0">
      <data key="d0">Pattern: If a driver has passed vehicle inspection and has the appropriate license, they can transport standard goods. -&gt; ForAll(x, (passed_vehicle_inspection(x) ∧ has_appropriate_license(x)) → can_transport_standard_goods(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["passed_vehicle_inspection", "has_appropriate_license"]</data>
      <data key="d4">["can_transport_standard_goods"]</data>
    </node>
    <node id="logic_rule_a6fcd750b74c12668fe5b7696a80682c">
      <data key="d0">Pattern: If a driver can transport standard goods and has completed hazmat training and received a safety endorsement, they can transport hazardous materials. -&gt; ForAll(x, (can_transport_standard_goods(x) ∧ completed_hazmat_training(x) ∧ received_safety_endorsement(x)) → can_transport_hazardous_materials(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["can_transport_standard_goods", "completed_hazmat_training", "received_safety_endorsement"]</data>
      <data key="d4">["can_transport_hazardous_materials"]</data>
    </node>
    <node id="logic_rule_89706dd2c61aa14f7515545a4f9c4f31">
      <data key="d0">Pattern: If a driver can transport hazardous materials and has an interstate permit, they can cross state lines with hazardous cargo. -&gt; ForAll(x, (can_transport_hazardous_materials(x) ∧ has_interstate_permit(x)) → can_cross_state_lines(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["can_transport_hazardous_materials", "has_interstate_permit"]</data>
      <data key="d4">["can_cross_state_lines"]</data>
    </node>
    <node id="logic_rule_75706d215e7bd6b28d17e34726e2dafc">
      <data key="d0">Pattern: Faculty members with a degree higher than BA can teach undergraduate courses. -&gt; ForAll(x, ForAll(d, (faculty_member(x) ∧ has_degree(x, d) ∧ higher(d, BA)) → teach_undergrad(x)))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["faculty_member", "has_degree", "higher"]</data>
      <data key="d4">["teach_undergrad"]</data>
    </node>
    <node id="logic_rule_9178fff8a78087acf72d840757aee3f1">
      <data key="d0">Pattern: Faculty members with a degree higher than MSc can teach graduate courses. -&gt; ForAll(x, ForAll(d, (faculty_member(x) ∧ has_degree(x, d) ∧ higher(d, MSc)) → teach_graduate(x)))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["faculty_member", "has_degree", "higher"]</data>
      <data key="d4">["teach_graduate"]</data>
    </node>
    <node id="logic_rule_6e31a2430ec8c6429c4dba8b8479be43">
      <data key="d0">Pattern: Anyone who teaches graduate courses can be a research mentor. -&gt; ForAll(x, teach_graduate(x) → research_mentor(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["teaches_graduate"]</data>
      <data key="d4">["research_mentor"]</data>
    </node>
    <node id="logic_rule_f0bb7a50fca21a85c7b91dc82606b82b">
      <data key="d0">Pattern: If degree A is higher than B, and B is higher than C, then A is higher than C. -&gt; ForAll(a, ForAll(b, ForAll(c, (higher(a, b) ∧ higher(b, c)) → higher(a, c))))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["higher(a, b)", "higher(b, c)"]</data>
      <data key="d4">["higher(a, c)"]</data>
    </node>
    <node id="logic_rule_7895e3096c51a286510391419f6d905e">
      <data key="d0">Pattern: If a curriculum is well-structured and has exercises, it enhances student engagement. -&gt; ForAll(c, (well_structured(c) ∧ has_exercises(c)) → enhances_engagement(c))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["well_structured", "has_exercises"]</data>
      <data key="d4">["enhances_engagement"]</data>
    </node>
    <node id="logic_rule_b5b27da7c5d8e6deaf4073a03754931a">
      <data key="d0">Pattern: If a curriculum enhances student engagement and provides access to advanced resources, it enhances critical thinking. -&gt; ForAll(c, (enhances_engagement(c) ∧ advanced_resources(c)) → enhances_critical_thinking(c))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["enhances_engagement", "advanced_resources"]</data>
      <data key="d4">["enhances_critical_thinking"]</data>
    </node>
    <node id="logic_rule_d39e12f4d1221a31d0a2cdb048ec4841">
      <data key="d0">Pattern: If a faculty prioritizes pedagogical training and curriculum development, the curriculum is well-structured. -&gt; ForAll(f, (pedagogical_training(f) ∧ curriculum_development(f)) → well_structured(curriculum))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
    </node>
    <node id="logic_rule_4b50d1a9e4bfd9e7db1bca3487776bad">
      <data key="d0">Pattern: If a student completes Course A, they can enroll in Course B. -&gt; ForAll(x, complete(x, A) → enroll(x, B))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["complete"]</data>
      <data key="d4">["enroll"]</data>
    </node>
    <node id="logic_rule_147a8fcfe53649af07c2c33369799834">
      <data key="d0">Pattern: If a student enrolls in Course B and passes it, they can enroll in Course C. -&gt; ForAll(x, (enroll(x, B) ∧ pass(x, B)) → enroll(x, C))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["enroll(x, B)", "pass(x, B)"]</data>
      <data key="d4">["enroll(x, C)"]</data>
    </node>
    <node id="logic_rule_294550b5b2042190715c8aae8c469071">
      <data key="d0">Pattern: Enrollment in Course C makes a student eligible for the internship program. -&gt; ForAll(x, enroll(x, C) → eligible_internship(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["enroll"]</data>
      <data key="d4">["eligible_internship"]</data>
    </node>
    <node id="logic_rule_b508e3a35e0ef0e333c7b38b838325ef">
      <data key="d0">Pattern: If a person has a valid membership card and has completed safety orientation, they can use equipment. -&gt; ForAll(x, (valid_membership(x) ∧ safety_orientation(x)) → use_equipment(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["valid_membership", "safety_orientation"]</data>
      <data key="d4">["use_equipment"]</data>
    </node>
    <node id="logic_rule_80647d12948141585b0c0ad0d0989050">
      <data key="d0">Pattern: If a person can use equipment and has a trainer, they can book training. -&gt; ForAll(x, (use_equipment(x) ∧ has_trainer(x)) → book_training(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["use_equipment", "has_trainer"]</data>
      <data key="d4">["book_training"]</data>
    </node>
    <node id="logic_rule_64106193d6e8a34be0d2f26b3aa1227d">
      <data key="d0">Pattern: If a person’s membership duration is at least 6 months, they are eligible for a trainer. -&gt; ForAll(x, (membership_duration(x) ≥ 6) → eligible_trainer(x))</data>
      <data key="d2">True</data>
      <data key="d1">True</data>
      <data key="d3">["membership_duration(x) \u2265 6"]</data>
      <data key="d4">["eligible_trainer(x)"]</data>
